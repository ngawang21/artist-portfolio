---
import ArtworkCard from './ArtworkCard.astro';
import type { LocalizedArtwork } from '../lib/artworks';

interface Props {
  groups: { year: number; items: LocalizedArtwork[] }[];
}
const { groups } = Astro.props;
let index = 0;
---

{
  groups.map(({ year, items }) => (
    <section class="year-block" id={`year-${year}`} aria-labelledby={`year-${year}-label`}>
      <header class="year-head">
        <h2 class="year-num" id={`year-${year}-label`}>
          {year}
        </h2>
        <span class="year-rule" aria-hidden="true" />
      </header>
      <div class="art-grid">
        {items.map((art, i) => (
          <ArtworkCard art={art} delay={i} loading={index++ < 3 ? 'eager' : 'lazy'} />
        ))}
      </div>
    </section>
  ))
}

<style>
  .year-block {
    margin-top: clamp(3.5rem, 10vh, 7rem);
    /* Land the year header clear of the fixed nav + sticky year bar on jump. */
    scroll-margin-top: calc(var(--nav-h) + 4.5rem);
  }
  .year-block:first-child {
    margin-top: 0;
  }
  .year-head {
    display: flex;
    align-items: baseline;
    gap: clamp(1rem, 3vw, 2rem);
    margin-bottom: clamp(1.75rem, 4.5vh, 3rem);
  }
  /* A quiet marker, clearly subordinate to the page title (the artist found the
     display-size year overwhelming) — the hairline rule keeps the separation. */
  .year-num {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 300;
    line-height: 1;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .year-rule {
    flex: 1;
    height: 1px;
    background: var(--line);
    transform: translateY(-0.4em);
  }
  .art-grid {
    --art-rowh: clamp(240px, 30vh, 360px);
    --art-gap: clamp(1.1rem, 2.4vw, 2.25rem);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: var(--art-gap);
  }
</style>
